P 2026-05-01 AAPL $200.00

2026-01-01 buy AAPL
    Assets:Stock          10 AAPL @ $100.00
    Assets:Cash         $-1,000.00

test bal --at 2026-06-01 --only-total --fmt json
{"ts":{"2026-06-01":{"AAPL":"10","$":"-1000.00"}}}
end test

test bal -V --at 2026-06-01 --only-total --fmt json
{"ts":{"2026-06-01":{"$":"1000.00"}}}
end test

test bal -B --at 2026-06-01 --only-total --fmt json
{"ts":{"2026-06-01":{}}}
end test

test bal -H --at 2026-06-01 --only-total --fmt json
{"ts":{"2026-06-01":{}}}
end test

test bal -V --at 2026-06-01 --only-total --fmt lisp
((ts ("2026-06-01" ("$" . "1000.00"))))
end test
