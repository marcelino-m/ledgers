{"accounts":["Assets:Bank","Expenses:Food","Income:Salary"],"commodities":["$"],"payees":["food","salary"]}
end test

test info --fmt lisp
((accounts "Assets:Bank" "Expenses:Food" "Income:Salary") (commodities "$") (payees "food" "salary"))
end test

